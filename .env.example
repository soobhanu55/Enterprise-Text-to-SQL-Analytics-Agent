# Copy to .env and adjust as needed. Defaults match docker-compose.yml.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/analytics
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/analytics

DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_MAX_OVERFLOW=10
QUERY_TIMEOUT_SECONDS=5.0
MAX_RESULT_ROWS=500

REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
SCHEMA_CACHE_TTL_SECONDS=3600
QUESTION_CACHE_TTL_SECONDS=600

# "mock" runs a deterministic offline rule-based NL2SQL engine (no API key/cost).
# Set to "anthropic" or "gemini" and provide the matching API key to use a real LLM.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GUARDRAIL_ROW_LIMIT_DEFAULT=200

LOG_LEVEL=INFO
APP_ENV=dev
