# Copy to .streamlit/secrets.toml for local testing, or paste these into
# "Settings -> Secrets" in the Streamlit Community Cloud app dashboard.
# NEVER commit .streamlit/secrets.toml (it's in .gitignore).

DATABASE_URL = "postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require"

# Optional -- omit entirely to use the in-memory cache fallback (fine for a
# single-instance Streamlit Cloud deployment; no separate Redis to host).
# REDIS_URL = "redis://default:PASSWORD@HOST:PORT"
CACHE_ENABLED = "true"

# "mock" = deterministic offline rule-based NL2SQL engine, $0, no key needed.
# "anthropic" = real LLM via the Claude API. "gemini" = real LLM via the Gemini API.
LLM_PROVIDER = "gemini"
ANTHROPIC_API_KEY = "sk-ant-..."
ANTHROPIC_MODEL = "claude-sonnet-5"
GEMINI_API_KEY = "AIza..."
GEMINI_MODEL = "gemini-2.0-flash"

MAX_RESULT_ROWS = "500"
QUERY_TIMEOUT_SECONDS = "5.0"
